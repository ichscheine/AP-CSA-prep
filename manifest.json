{
  "manifest_version": 3,
  "name": "CSAwesome Prep Coach",
  "version": "0.1.1",
  "description": "Daily AP CSA roadmap and mastery checklist overlay for CSAwesome on Runestone.",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://runestone.academy/ns/books/published/csawesome2/*"],
      "js": ["schedule.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
